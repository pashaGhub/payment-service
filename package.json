{
  "name": "payment-service",
  "version": "1.0.0",
  "description": "service for different payment providers under a unified architecture",
  "keywords": [
    "node",
    "typescript",
    "express",
    "zod"
  ],
  "license": "ISC",
  "author": "Pavel Sucharev",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "prettier-fix": "prettier --write .",
    "prettier-check": "prettier --check .",
    "seed": "NODE_ENV=dev node db/seed.js",
    "clean-db": "rimraf data",
    "reseed": "npm run clean-db && npm run seed",
    "test": "NODE_ENV=test node db/seed.js && jest --detectOpenHandles --coverage",
    "coverage": "open-cli coverage/lcov-report/index.html",
    "test:coverage": "npm test && npm run coverage"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "open-cli": "^9.0.0",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
