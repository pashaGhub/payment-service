PORT=3000
DB_PATH=./data/payments.db
NODE_ENV=dev

# The service's own per-PSP account credentials, keyed by PSP code:
#   PSP_<CODE>_API_KEY, PSP_<CODE>_WEBHOOK_SECRET
# Mock defaults are used when unset (see src/config/psp.ts).
PSP_MOCK_CARD_API_KEY=mock_api_key
PSP_MOCK_CARD_WEBHOOK_SECRET=whsec_mock
PSP_MOCK_WALLET_API_KEY=mock_api_key
PSP_MOCK_WALLET_WEBHOOK_SECRET=whsec_mock
